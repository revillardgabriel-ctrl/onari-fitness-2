<!DOCTYPE html>

<html class="light" lang="fr"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#06b6d4",
                        "background-light": "#ffffff",
                    },
                    fontFamily: {
                        "display": ["Public Sans", "sans-serif"]
                    },
                    boxShadow: {
                        'soft': '0 10px 30px -5px rgba(0, 0, 0, 0.04), 0 4px 12px -3px rgba(0, 0, 0, 0.02)',
                        'card': '0 20px 40px -12px rgba(0, 0, 0, 0.06)',
                    },
                    borderRadius: {"DEFAULT": "0.75rem", "lg": "1rem", "xl": "1.25rem", "2xl": "1.75rem", "full": "9999px"},
                },
            },
        }
    </script>
<style>
        body { font-family: 'Public Sans', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .active-icon { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        
        /* Custom RPE Slider Styling */
        input[type=range].rpe-slider {
            -webkit-appearance: none;
            width: 100%;
            background: transparent;
        }
        input[type=range].rpe-slider::-webkit-slider-runnable-track {
            height: 6px;
            background: linear-gradient(to right, #06b6d4, #0ea5e9);
            border-radius: 999px;
        }
        input[type=range].rpe-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 22px;
            width: 22px;
            background: white;
            border: 3px solid #06b6d4;
            border-radius: 50%;
            margin-top: -8px;
            box-shadow: 0 4px 10px rgba(6, 182, 212, 0.3);
            cursor: pointer;
        }
        
        /* Hide arrows in number inputs */
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .circular-progress {
            background: conic-gradient(#06b6d4 180deg, #f1f5f9 0deg);
            border-radius: 50%;
            width: 200px;
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .circular-progress::before {
            content: "";
            position: absolute;
            width: 170px;
            height: 170px;
            background: white;
            border-radius: 50%;
        }
    </style>
</head>
<body class="bg-[#fafafa] text-slate-900 antialiased font-display">
<!-- Main Container -->
<div class="relative flex min-h-screen w-full flex-col max-w-md mx-auto bg-white shadow-[0_0_50px_rgba(0,0,0,0.05)] overflow-hidden">
<!-- Header -->
<header class="sticky top-0 z-30 bg-white/90 backdrop-blur-xl px-6 pt-6 pb-4">
<div class="flex items-center justify-between mb-4">
<button class="p-2 -ml-2 text-slate-400 hover:bg-slate-50 rounded-full transition-colors">
<span class="material-symbols-outlined text-2xl">close</span>
</button>
<div class="text-center">
<p class="text-[11px] font-black text-slate-400 uppercase tracking-[0.25em] mb-0.5">Push Workout</p>
<h2 class="text-base font-extrabold text-slate-900">Exercice 3 sur 6</h2>
</div>
<button class="text-primary font-extrabold text-sm tracking-tight hover:opacity-80">Terminer</button>
</div>
<!-- Progress Bar -->
<div class="px-1">
<div class="flex justify-between items-center mb-2">
<span class="text-[10px] font-extrabold text-slate-400 uppercase tracking-widest">Progression</span>
<span class="text-[10px] font-black text-primary">50% complété</span>
</div>
<div class="h-1.5 w-full bg-slate-100 rounded-full overflow-hidden">
<div class="h-full bg-primary rounded-full transition-all duration-500 ease-out" style="width: 50%;"></div>
</div>
</div>
</header>
<main class="flex-1 overflow-y-auto pb-32">
<!-- Video Player Integrated -->
<div class="px-4 mt-2">
<div class="aspect-video w-full bg-slate-900 relative rounded-2xl overflow-hidden shadow-lg group">
<img alt="Bench Press Tutorial" class="w-full h-full object-cover opacity-70 group-hover:scale-105 transition-transform duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBuP2fuDaIGEwLAgOh-0gmZkrXzGRcnDLxzfnp7fb6abwG466Bg_e4cX1oyh5ikIg7Cxo_3iGiCTp44S5513rcvPx_UCRtJtmWOGPbUDrBjZZIMIzC5fBF266v4X3hK8UjTJIHDS1Y4n9mgNvAK5VIXKxwD71HmHcOZTzsWuq-ukGs84-0WU0Thv8385zZK0VhLYbLJaRLapUlUxzAS1_1-ChlB_a5SJFG7RMgJH4yewVs6i77lflZ40Rkvg71g3YvBtNEjrQ4k-iPY"/>
<div class="absolute inset-0 flex items-center justify-center bg-black/10">
<div class="size-16 rounded-full bg-white/20 backdrop-blur-md border border-white/40 flex items-center justify-center cursor-pointer hover:scale-110 active:scale-95 transition-all">
<span class="material-symbols-outlined text-white text-4xl active-icon ml-1">play_arrow</span>
</div>
</div>
<div class="absolute bottom-4 left-4">
<span class="text-[9px] font-black text-white uppercase tracking-widest bg-black/40 backdrop-blur-sm px-2.5 py-1 rounded-lg border border-white/10">Tutoriel Vidéo</span>
</div>
</div>
</div>
<!-- Exercise Info -->
<div class="px-6 pt-8 pb-4">
<h1 class="text-[32px] font-black text-slate-900 tracking-tight leading-none mb-2">Développé Couché</h1>
<p class="text-slate-400 text-sm font-semibold tracking-wide">Pectoraux • Triceps • Épaules</p>
</div>
<!-- Sets List -->
<div class="px-4 space-y-4">
<!-- Set 1 (Done) -->
<div class="bg-white rounded-2xl p-5 shadow-soft border border-slate-50 opacity-60">
<div class="flex items-center gap-4 mb-5">
<div class="size-10 rounded-full bg-slate-100 flex items-center justify-center text-xs font-black text-slate-400">1</div>
<div class="flex-1 grid grid-cols-2 gap-6">
<div class="flex flex-col">
<span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Poids (kg)</span>
<div class="flex items-baseline gap-2">
<span class="text-2xl font-black text-slate-800">80</span>
<span class="text-[10px] font-bold text-slate-300">Prev: 75</span>
</div>
</div>
<div class="flex flex-col">
<span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Reps</span>
<div class="flex items-baseline gap-2">
<span class="text-2xl font-black text-slate-800">10</span>
<span class="text-[10px] font-bold text-slate-300">Obj: 8-12</span>
</div>
</div>
</div>
</div>
<div class="flex justify-between items-center px-1">
<span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">RPE 7/10</span>
<div class="h-1 w-32 bg-slate-100 rounded-full">
<div class="h-full bg-slate-300 rounded-full w-[70%]"></div>
</div>
</div>
</div>
<!-- Set 2 (Active) -->
<div class="bg-white rounded-[2rem] p-6 shadow-card border border-primary/10 ring-1 ring-primary/5 relative overflow-hidden">
<div class="absolute top-0 right-0 p-4">
<span class="material-symbols-outlined text-primary/20 text-4xl">edit_note</span>
</div>
<div class="flex items-center gap-4 mb-6">
<div class="size-12 rounded-full bg-primary flex items-center justify-center text-sm font-black text-white shadow-lg shadow-primary/30">2</div>
<div class="flex-1 grid grid-cols-2 gap-4">
<div class="flex flex-col">
<label class="text-[10px] font-black text-primary uppercase tracking-widest mb-2">Poids (kg)</label>
<div class="flex items-center">
<input class="w-full p-0 text-3xl font-black border-none focus:ring-0 bg-transparent text-slate-900 tabular-nums" type="number" value="82.5"/>
</div>
<span class="text-[10px] font-bold text-slate-400 mt-1">Prev: 80 kg</span>
</div>
<div class="flex flex-col border-l border-slate-100 pl-4">
<label class="text-[10px] font-black text-primary uppercase tracking-widest mb-2">Répétitions</label>
<div class="flex items-center">
<input class="w-full p-0 text-3xl font-black border-none focus:ring-0 bg-transparent text-slate-900 placeholder-slate-200 tabular-nums" placeholder="0" type="number"/>
</div>
<span class="text-[10px] font-bold text-slate-400 mt-1">Objectif: 8-12</span>
</div>
</div>
</div>
<div class="mt-8">
<div class="flex justify-between items-center mb-4">
<span class="text-[11px] font-black text-slate-900 uppercase tracking-[0.15em]">Intensité (RPE)</span>
<div class="px-3 py-1 bg-primary/10 rounded-full">
<span class="text-xs font-black text-primary">8.5 / 10</span>
</div>
</div>
<input class="rpe-slider mb-3" max="10" min="1" step="0.5" type="range" value="8.5"/>
<div class="flex justify-between px-1">
<span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Léger</span>
<span class="text-[9px] font-black text-primary uppercase tracking-widest">Modéré</span>
<span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Échec</span>
</div>
</div>
</div>
<!-- Set 3 (Next) -->
<div class="bg-white rounded-2xl p-5 shadow-soft border border-slate-50">
<div class="flex items-center gap-4">
<div class="size-10 rounded-full bg-slate-50 flex items-center justify-center text-xs font-black text-slate-400">3</div>
<div class="flex-1 flex items-center justify-between">
<span class="text-sm font-extrabold text-slate-300 uppercase tracking-widest">Série suivante</span>
<span class="text-xs font-bold text-slate-400">82.5 kg • 8-12 reps</span>
</div>
</div>
</div>
</div>
<!-- Rest Timer - Graphical Style -->
<div class="mt-12 mb-12 flex flex-col items-center">
<div class="circular-progress shadow-xl shadow-slate-200/50">
<div class="relative z-10 flex flex-col items-center">
<span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-1">Récupération</span>
<div class="text-5xl font-black text-slate-900 tracking-tighter tabular-nums">01:30</div>
</div>
</div>
<div class="flex gap-4 -mt-8 relative z-20">
<button class="size-14 rounded-full bg-white border border-slate-100 flex items-center justify-center text-slate-900 font-black shadow-lg shadow-slate-200/50 active:scale-90 transition-transform">-30s</button>
<button class="h-14 px-10 rounded-full bg-primary text-white font-black shadow-xl shadow-primary/40 active:scale-95 transition-all flex items-center gap-2">
<span class="material-symbols-outlined text-xl">timer</span>
<span>+30s</span>
</button>
</div>
</div>
<!-- Up Next Preview -->
<div class="px-6 mb-12">
<h3 class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4">Exercice Suivant</h3>
<div class="group flex items-center gap-4 p-4 rounded-3xl bg-white border border-slate-100 shadow-soft hover:shadow-card transition-all cursor-pointer">
<div class="size-16 rounded-2xl bg-slate-100 overflow-hidden shrink-0 shadow-sm">
<img alt="Shoulder Press" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDZbsbAHXz7RDjDI0zmvffDLr4Jg7kKOR44awwSn9s4KlQeJDcGcJSh_yH9QNYclmmiTxP_vvDIBaG6mm_LJAA7tWWomQpICqDBnyLkHC0lkUpALF5foq8D9OrPUam3ZFQHiZ2HKWFrWGhnNSAdD3Wt_Io5zd1c23BRcMHRutNjpGHJNnqYz7U6Wv_ius2aNi6nrL5ldcLzV55cmlDmsDd4NI8H-jg9uWk4KyriHPqPlhvcEC0EtZUeoaS0hmVcHbgOTwdEtV1PYzj0"/>
</div>
<div class="flex-1 min-w-0">
<h4 class="text-[15px] font-black text-slate-900 truncate tracking-tight">Développé Militaire</h4>
<p class="text-xs text-slate-400 font-semibold mt-0.5 uppercase tracking-wider">3 séries • Épaules</p>
</div>
<div class="size-8 rounded-full bg-slate-50 flex items-center justify-center">
<span class="material-symbols-outlined text-slate-300 text-xl">chevron_right</span>
</div>
</div>
</div>
</main>
<!-- Navigation Bar -->
<nav class="fixed bottom-0 left-0 right-0 max-w-md mx-auto bg-white/95 backdrop-blur-xl border-t border-slate-50 flex items-center justify-around px-2 pb-8 pt-4 z-40">
<a class="flex flex-col items-center gap-1.5 text-slate-400" href="#">
<span class="material-symbols-outlined">dashboard</span>
<span class="text-[9px] font-black uppercase tracking-widest">Résumé</span>
</a>
<a class="flex flex-col items-center gap-1.5 text-slate-400" href="#">
<span class="material-symbols-outlined">event_note</span>
<span class="text-[9px] font-black uppercase tracking-widest">Programme</span>
</a>
<a class="flex flex-col items-center gap-1.5 text-primary relative" href="#">
<div class="absolute -top-4 size-1.5 bg-primary rounded-full shadow-[0_0_10px_#06b6d4]"></div>
<span class="material-symbols-outlined active-icon text-[28px]">fitness_center</span>
<span class="text-[9px] font-black uppercase tracking-widest">Prog</span>
</a>
<a class="flex flex-col items-center gap-1.5 text-slate-400" href="#">
<span class="material-symbols-outlined">restaurant</span>
<span class="text-[9px] font-black uppercase tracking-widest">Nutrition</span>
</a>
<a class="flex flex-col items-center gap-1.5 text-slate-400" href="#">
<span class="material-symbols-outlined">account_circle</span>
<span class="text-[9px] font-black uppercase tracking-widest">Profil</span>
</a>
</nav>
</div>
</body></html>